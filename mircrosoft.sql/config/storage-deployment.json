{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "5932331581688917490"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "storageSKU": {
      "type": "string",
      "defaultValue": "Standard_LRS"
    },
    "environment": {
      "type": "string",
      "defaultValue": "dev"
    },
    "sasExpiry": {
      "type": "string",
      "defaultValue": "[dateTimeAdd(utcNow(), 'P365D')]"
    }
  },
  "variables": {
    "storageAccountName": "[format('{0}connectplusfs', parameters('environment'))]",
    "containerName": "[format('{0}connectplusfile', parameters('environment'))]",
    "sasConfig": {
      "signedExpiry": "[parameters('sasExpiry')]",
      "signedResourceTypes": "sco",
      "signedPermission": "rwdl",
      "signedServices": "b",
      "signedProtocol": "https"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2022-05-01",
      "name": "[toLower(variables('storageAccountName'))]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('storageSKU')]"
      },
      "kind": "StorageV2",
      "properties": {
        "supportsHttpsTrafficOnly": true,
        "allowBlobPublicAccess": false,
        "minimumTlsVersion": "TLS1_2",
        "encryption": {
          "keySource": "Microsoft.Storage",
          "services": {
            "blob": {
              "enabled": true
            }
          }
        }
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2022-05-01",
      "name": "[format('{0}/default/{1}', toLower(variables('storageAccountName')), variables('containerName'))]",
      "properties": {
        "publicAccess": "None"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', toLower(variables('storageAccountName')))]"
      ]
    }
  ],
  "outputs": {
    "connectionStringSAS": {
      "type": "string",
      "value": "[format('BlobEndpoint={0};SharedAccessSignature={1}', reference(resourceId('Microsoft.Storage/storageAccounts', toLower(variables('storageAccountName'))), '2022-05-01').primaryEndpoints.blob, listAccountSas(resourceId('Microsoft.Storage/storageAccounts', toLower(variables('storageAccountName'))), '2022-05-01', variables('sasConfig')).accountSasToken)]"
    }
  }
}